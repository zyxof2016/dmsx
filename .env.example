#
# DMSX 本地/内测环境变量模板（请复制为 .env 并自行替换；不要提交真实密钥）
#
# 用法示例：
#   set -a && source .env && set +a
#   cargo run -p dmsx-api
#

# --- dmsx-api ---
# 建议本地只绑定回环，避免误暴露到公网
DMSX_API_BIND=127.0.0.1:8080

# 内测/本地可用 disabled；生产必须使用 jwt + OIDC/JWKS 并强制 iss/aud
DMSX_API_AUTH_MODE=disabled

# Postgres（开发 compose 默认）
DATABASE_URL=postgres://dmsx:dmsx@127.0.0.1:5432/dmsx

# 若使用 jwt（HS256）模式，务必替换为强随机密钥；不要提交到仓库
# DMSX_API_JWT_SECRET=change-me-please

# 若启用 OIDC/JWKS，以下必填（且应来自真实 IdP 配置）
# DMSX_API_OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
# DMSX_API_JWT_ISSUER=https://idp.example.com/realms/dmsx
# DMSX_API_JWT_AUDIENCE=dmsx-api

# /metrics：默认启用；如需限制访问，可配置固定 bearer（不要提交真实值）
# DMSX_API_METRICS_ENABLED=true
# DMSX_API_METRICS_BEARER=change-me-please

# LiveKit（仅远程桌面相关需要；不要提交真实 secret）
# LIVEKIT_URL=ws://127.0.0.1:7880
# LIVEKIT_API_KEY=dmsx-api-key
# LIVEKIT_API_SECRET=dmsx-api-secret-that-is-at-least-32-chars

